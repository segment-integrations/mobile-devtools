{
  "include": ["path:../../plugins/ios/plugin.json"],
  "packages": {
    "process-compose": "latest"
  },
  "shell": {
    "scripts": {
      "build": [
        "ios.sh build"
      ],
      "build:release": [
        "ios.sh build --config Release"
      ],
      "start:app": [
        "ios.sh run ${1:-}"
      ],
      "test": [
        "ios.sh build --action test"
      ],
      "test:e2e": [
        "process-compose -f tests/test-suite.yaml --no-server --tui=${TEST_TUI:-false}"
      ]
    }
  }
}
